{
  "version": 1,
  "id": "ledger",
  "name": "Ledger",
  "display": {
    "title": "Ledger",
    "icon": "assets/remux/ledger.png"
  },
  "server": {
    "transport": "stdio",
    "build": {
      "command": "cargo",
      "args": [
        "build",
        "--release",
        "-p",
        "ledger-remux",
        "--target-dir",
        "/tmp/remux-ledger-server-target",
        "--quiet"
      ],
      "cwd": "."
    },
    "command": "/tmp/remux-ledger-server-target/release/ledger-remux",
    "args": [],
    "cwd": "."
  },
  "views": {
    "main": {
      "route": "/viewers/ledger",
      "entry": "lens/dist/index.html",
      "build": {
        "command": "npm",
        "args": [
          "run",
          "build"
        ],
        "cwd": "lens"
      },
      "watch": {
        "command": "npm",
        "args": [
          "run",
          "watch"
        ],
        "cwd": "lens"
      }
    }
  },
  "launchers": [
    {
      "id": "data-center",
      "view": "main",
      "label": "Ledger"
    }
  ],
  "fileHandlers": []
}
